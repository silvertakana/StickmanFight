{
  "manifest_version": 3,
  "name": "Stickman Fight",
  "version": "1.0.0",
  "description": "Turn any webpage into a physics playground — fight as a stickman on live websites!",
  "permissions": [
    "activeTab"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.js-loader-Cso4FM8t.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/*",
        "src/*",
        "assets/chunk-CTC_7jcf.js",
        "assets/Boss-Dhnj297Q.js",
        "assets/content.js-B8tgvqYS.js"
      ],
      "use_dynamic_url": false
    }
  ],
  "commands": {
    "toggle-game": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Toggle Stickman Fight"
    }
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
